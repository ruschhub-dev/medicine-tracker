# Copie este arquivo para .env.local e preencha com os dados do seu projeto Supabase.
# (Project Settings -> API no painel do Supabase)
# Enquanto estes valores estiverem vazios, o app roda em modo local (dados no navegador).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Web Push (VAPID) — gere com: node scripts/gen-vapid.mjs
VITE_VAPID_PUBLIC_KEY=

# CAPTCHA no cadastro (opcional). Cloudflare Turnstile: crie um site em
# dash.cloudflare.com e habilite o CAPTCHA no Supabase (Auth -> Settings).
# Sem esta chave, o CAPTCHA fica desligado e o app funciona normalmente.
VITE_TURNSTILE_SITE_KEY=

# Anúncios (opcional, só no plano grátis). Google AdSense.
# Sem estas chaves, nenhum anúncio aparece.
VITE_ADSENSE_CLIENT=
VITE_ADSENSE_SLOT=

# --- Só no servidor (defina na Vercel, NÃO aqui no cliente): ---
# MP_ACCESS_TOKEN      -> token do Mercado Pago (assinatura Premium)
# MP_PRICE             -> preço mensal, ex.: 9.90
# MP_REASON            -> descrição da assinatura (opcional)
# APP_URL              -> domínio do deploy (back_url do checkout e link do e-mail)
# SUPABASE_SERVICE_ROLE_KEY, CRON_SECRET, VAPID_PRIVATE_KEY, GMAIL_USER/GMAIL_APP_PASSWORD
