# Copie este arquivo para .env.local e preencha com os dados do seu projeto Supabase.
# (Project Settings -> API no painel do Supabase)
# Enquanto estes valores estiverem vazios, o app roda em modo local (dados no navegador).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Web Push (VAPID) — gere com: node scripts/gen-vapid.mjs
VITE_VAPID_PUBLIC_KEY=

# CAPTCHA no cadastro (opcional). Cloudflare Turnstile: crie um site em
# dash.cloudflare.com e habilite o CAPTCHA no Supabase (Auth -> Settings).
# Sem esta chave, o CAPTCHA fica desligado e o app funciona normalmente.
VITE_TURNSTILE_SITE_KEY=
